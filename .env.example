# Copier vers .env : `cp .env.example .env`
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
KAFKA_HOST_PORT=9092

# Redis (compose : service redis ; payment-service profil docker)
# REDIS_HOST_PORT=6379
# REDIS_PASSWORD=
CACHE_REDIS_ENABLED=true
# CACHE_WALLET_BALANCE_TTL=PT30S

# Pool R2DBC payment-service (optionnel, défauts = YAML)
# R2DBC_POOL_MAX_SIZE=5
# R2DBC_POOL_MAX_ACQUIRE_TIME=30s

# JWT HMAC (Base64, >= 32 octets décodés) - générer : openssl rand -base64 32
JWT_SECRET=B7lNty52nURS1lCg6KjEvPh6e71c/ndOh1H4mCMRMgo=

# Clé API pour les backends appelant payment-service (wallets / transactions)
# Générer : openssl rand -hex 32
PAYMENT_INTERNAL_API_KEY=dev-payment-internal-key-min-16chars

# Swagger / OpenAPI (true en dev, false recommandé en prod)
EXPOSE_OPENAPI=true

# Origines CORS séparées par des virgules
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3999

# Plafonds métier (optionnel)
# MAX_TRANSACTION_AMOUNT=1000000
# MAX_RECHARGE_AMOUNT=1000000

# --- Frontend Next.js (BFF) - dev sur l’hôte ---
PAYMENT_SERVICE_BASE_URL=http://localhost:8090
USER_PAYMENT_BASE_URL=http://localhost:8091
# Même secret Base64 que les services Java (validation cookie côté BFF)
# JWT_SECRET= (déjà défini ci-dessus)
# PAYMENT_INTERNAL_API_KEY= (déjà défini ci-dessus)

# Cookie session httpOnly (frontend-payment-main)
SESSION_COOKIE_NAME=yowyob_session
SESSION_COOKIE_SECURE=false
SESSION_MAX_AGE_SECONDS=3600

# --- Frontend Next.js (BFF) - copier aussi dans frontend-payment-main/.env.local ---
# PAYMENT_SERVICE_BASE_URL=http://localhost:8090
# USER_PAYMENT_BASE_URL=http://localhost:8091
# PAYMENT_INTERNAL_API_KEY=dev-payment-internal-key-min-16chars
# JWT_SECRET=<même valeur que ci-dessus>
# SESSION_COOKIE_NAME=yowyob_session
# SESSION_MAX_AGE_SECONDS=3600
# SESSION_COOKIE_SECURE=false
